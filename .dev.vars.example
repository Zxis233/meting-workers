SECRET_DOMAIN= # 必填：允许访问的域名白名单，逗号分隔
AUTH_SECRET= # 必填：用于生成 auth 签名
NETEASE_COOKIE= # 可选：网易云 Cookie
TENCENT_COOKIE= # 可选：QQ 音乐 Cookie
NETEASE_COOKIE_CHECK_URL=https://meting.esing.dev/?server=netease&type=song&id=31134338 # 可选：定时检查 Cookie 的歌曲接口
NETEASE_COOKIE_REFRESH_ENABLED=true # 可选：保留项；手动刷新接口会强制执行
TELEGRAM_BOT_ID= # 可选：Telegram Bot API Token，用于 Cookie 检查/刷新推送
TELEGRAM_CHAT_ID= # 可选：Telegram Chat ID，与 TELEGRAM_BOT_ID 同时配置才启用推送
